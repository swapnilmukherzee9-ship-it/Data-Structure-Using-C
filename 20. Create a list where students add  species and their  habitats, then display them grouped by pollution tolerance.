#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Species {
    char name[50];
    char habitat[50];
    char tolerance[20]; 
    struct Species* next;
};

struct Species* createNode(char name[], char habitat[], char tolerance[]) {
    struct Species* newNode = (struct Species*)malloc(sizeof(struct Species));
    strcpy(newNode->name, name);
    strcpy(newNode->habitat, habitat);
    strcpy(newNode->tolerance, tolerance);
    newNode->next = NULL;
    return newNode;
}

void insert(struct Species** head, char name[], char habitat[], char tolerance[]) {
    struct Species* newNode = createNode(name, habitat, tolerance);

    if (*head == NULL) {
        *head = newNode;
        return;
    }

    struct Species* temp = *head;
    while (temp->next != NULL) {
        temp = temp->next;
    }
    temp->next = newNode;
}

void displayByTolerance(struct Species* head, char level[]) {
    struct Species* temp = head;
    int found = 0;

    printf("\n--- %s Pollution Tolerance ---\n", level);
    while (temp != NULL) {
        if (strcmp(temp->tolerance, level) == 0) {
            printf("Species: %s | Habitat: %s\n", temp->name, temp->habitat);
            found = 1;
        }
        temp = temp->next;
    }

    if (!found) {
        printf("No records found.\n");
    }
}

int main() {
    struct Species* head = NULL;
    int n;
    char name[50], habitat[50], tolerance[20];

    printf("Enter number of species: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("\nEnter species name: ");
        scanf("%s", name);

        printf("Enter habitat: ");
        scanf("%s", habitat);

        printf("Enter pollution tolerance (High/Medium/Low): ");
        scanf("%s", tolerance);
        insert(&head, name, habitat, tolerance);
    }

    displayByTolerance(head, "High");
    displayByTolerance(head, "Medium");
    displayByTolerance(head, "Low");
    return 0;
}
